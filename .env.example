# Jira Configuration
# Required for sync_jira.py script

# Jira instance URL (e.g., https://yourcompany.atlassian.net)
JIRA_URL=https://jira.example.com

# Jira authentication
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# Jira project configuration
JIRA_PROJECT_KEY=PROJ
JIRA_BOARD_ID=123

# GitLab Configuration (optional, for browser-based comment commits)
# GITLAB_TOKEN=your-gitlab-personal-access-token

# Gist Configuration (required for storing sprint data)
# Set these as repository secrets and pass as env vars during build
VITE_GIST_ID=your-gist-id
VITE_GIST_TOKEN=your-github-token-with-gist-scope
